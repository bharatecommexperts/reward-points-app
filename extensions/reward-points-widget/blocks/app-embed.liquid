{% comment %} Reward Points Widget {% endcomment %}

<div id="rp-floating-btn" onclick="rpToggleWidget()" style="position:fixed;bottom:30px;right:20px;background:#667eea;color:white;padding:12px 20px;border-radius:50px;cursor:pointer;display:flex;align-items:center;gap:8px;font-size:14px;font-weight:bold;box-shadow:0 4px 15px rgba(0,0,0,0.2);z-index:9999;transition:transform 0.2s;">
  <span>🎁</span>
  <span id="rp-btn-text">{% if customer %}Loading...{% else %}My Rewards{% endif %}</span>
</div>

<div id="rp-popup" style="display:none;position:fixed;bottom:100px;right:20px;width:300px;background:white;border-radius:16px;box-shadow:0 10px 40px rgba(0,0,0,0.15);z-index:9998;overflow:hidden;">
  <div style="background:#667eea;color:white;padding:16px 20px;display:flex;justify-content:space-between;align-items:center;font-weight:bold;font-size:16px;">
    <span>🏆 My Rewards</span>
    <button onclick="rpToggleWidget()" style="background:none;border:none;color:white;cursor:pointer;font-size:18px;padding:0;">✕</button>
  </div>

  <div style="padding:20px;max-height:450px;overflow-y:auto;">

    {% if customer %}
      <div id="rp-loading" style="text-align:center;color:#888;padding:20px;">Loading your points...</div>
      <div id="rp-content" style="display:none;">
        <div style="text-align:center;background:linear-gradient(135deg,#667eea,#764ba2);color:white;border-radius:12px;padding:20px;margin-bottom:16px;">
          <div id="rp-points-number" style="font-size:48px;font-weight:bold;line-height:1;">0</div>
          <div style="font-size:14px;opacity:0.9;margin-top:4px;">Points</div>
          <div style="font-size:16px;margin-top:8px;background:rgba(255,255,255,0.2);border-radius:20px;padding:4px 12px;display:inline-block;">
            Worth <span id="rp-rupees">{{ cart.currency.symbol }}0</span>
          </div>
        </div>
        <button id="rp-redeem-btn" onclick="rpRedeem()" style="display:none;width:100%;background:#667eea;color:white;border:none;padding:12px;border-radius:8px;cursor:pointer;font-size:15px;font-weight:bold;margin-bottom:16px;">🎉 Redeem Points</button>
        <p id="rp-min-msg" style="display:none;text-align:center;color:#888;font-size:13px;margin-bottom:16px;"></p>
        <div id="rp-success" style="display:none;text-align:center;margin-bottom:16px;">
          <p style="font-weight:bold;color:#28a745;">🎉 Points Redeemed!</p>
          <p>Your code:</p>
          <div id="rp-code-display" style="background:#f0f0f0;border:2px dashed #ccc;border-radius:8px;padding:12px;font-size:18px;font-weight:bold;letter-spacing:2px;margin:8px 0;word-break:break-all;"></div>
          <button onclick="rpCopyCode()" style="background:#28a745;color:white;border:none;padding:8px 16px;border-radius:6px;cursor:pointer;font-size:13px;">📋 Copy Code</button>
          <p id="rp-copy-msg" style="display:none;color:#28a745;font-size:12px;margin-top:4px;">Copied!</p>
        </div>
        <div style="font-weight:bold;font-size:14px;color:#333;margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid #eee;">Recent Activity</div>
        <div id="rp-history-list"></div>
      </div>

    {% else %}
      <div style="text-align:center;padding:24px 16px;">
        <div style="font-size:48px;margin-bottom:12px;">🎁</div>
        <h3 style="font-size:18px;font-weight:bold;color:#333;margin:0 0 8px;">Earn Reward Points!</h3>
        <p style="color:#666;font-size:14px;margin-bottom:20px;line-height:1.5;">
          Login to earn points on every purchase and get discounts.
        </p>
        <a href="/account/login?return_url={{ request.path | url_encode }}"
           style="display:block;background:#667eea;color:white;padding:12px;border-radius:8px;text-decoration:none;font-weight:bold;font-size:15px;margin-bottom:10px;text-align:center;">
          🔐 Login to View Points
        </a>
        <a href="/account/register"
           style="display:block;background:#f5f5f5;color:#333;padding:12px;border-radius:8px;text-decoration:none;font-weight:bold;font-size:15px;text-align:center;">
          ✨ Create Account
        </a>
      </div>
    {% endif %}

  </div>
</div>

<style>
  #rp-floating-btn:hover { transform: scale(1.05); }
  #rp-redeem-btn:hover { opacity: 0.9; }
  #rp-redeem-btn:disabled { opacity: 0.6; cursor: not-allowed; }
</style>

{% if customer %}
<script>
(function() {
  var customerId = "{{ customer.id }}";
  var shop = "{{ shop.permanent_domain }}";
  var currencyCode = "{{ cart.currency.iso_code }}";
  var currentCode = '';

  function formatMoney(amount) {
    try {
      return new Intl.NumberFormat('en-IN', {
        style: 'currency', currency: currencyCode,
        minimumFractionDigits: 2, maximumFractionDigits: 2
      }).format(amount);
    } catch(e) { return amount; }
  }

  fetch('/apps/rewards/points?customerId=' + customerId + '&shop=' + shop)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      document.getElementById('rp-btn-text').textContent = data.totalPoints + ' pts';
      document.getElementById('rp-points-number').textContent = data.totalPoints;
      document.getElementById('rp-rupees').textContent = formatMoney(data.discountValue);
      document.getElementById('rp-loading').style.display = 'none';
      document.getElementById('rp-content').style.display = 'block';

      if (data.canRedeem) {
        document.getElementById('rp-redeem-btn').style.display = 'block';
      } else {
        document.getElementById('rp-min-msg').style.display = 'block';
        document.getElementById('rp-min-msg').textContent =
          'Earn ' + (data.minPointsToRedeem - data.totalPoints) + ' more points to redeem!';
      }

      fetch('/apps/rewards/history?customerId=' + customerId + '&shop=' + shop)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var list = document.getElementById('rp-history-list');
          if (data.transactions && data.transactions.length > 0) {
            list.innerHTML = data.transactions.slice(0, 5).map(function(t) {
              return '<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f5f5f5;font-size:13px;">' +
                '<span>' + (t.description || (t.type === 'earn' ? 'Points Earned' : 'Points Redeemed')) + '</span>' +
                '<span style="color:' + (t.type === 'earn' ? '#28a745' : '#dc3545') + ';font-weight:bold;">' +
                (t.type === 'earn' ? '+' : '') + t.points + ' pts</span></div>';
            }).join('');
          } else {
            list.innerHTML = '<div style="color:#888;font-size:13px;text-align:center;">No activity yet</div>';
          }
        }).catch(function() {});
    })
    .catch(function() {
      document.getElementById('rp-loading').textContent = 'Could not load points.';
    });

  window.rpToggleWidget = function() {
    var popup = document.getElementById('rp-popup');
    popup.style.display = popup.style.display === 'none' ? 'block' : 'none';
  };

  window.rpRedeem = function() {
    var btn = document.getElementById('rp-redeem-btn');
    btn.disabled = true;
    btn.textContent = 'Processing...';
    fetch('/apps/rewards/redeem', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ customerId: customerId, shop: shop })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        currentCode = data.discountCode;
        document.getElementById('rp-redeem-btn').style.display = 'none';
        document.getElementById('rp-success').style.display = 'block';
        document.getElementById('rp-code-display').textContent = data.discountCode;
        document.getElementById('rp-points-number').textContent = '0';
        document.getElementById('rp-rupees').textContent = formatMoney(0);
        document.getElementById('rp-btn-text').textContent = '0 pts';
      } else {
        btn.disabled = false;
        btn.textContent = '🎉 Redeem Points';
        alert(data.error || 'Something went wrong');
      }
    })
    .catch(function() {
      btn.disabled = false;
      btn.textContent = '🎉 Redeem Points';
      alert('Something went wrong. Please try again.');
    });
  };

  window.rpCopyCode = function() {
    navigator.clipboard.writeText(currentCode).then(function() {
      document.getElementById('rp-copy-msg').style.display = 'block';
      setTimeout(function() {
        document.getElementById('rp-copy-msg').style.display = 'none';
      }, 2000);
    });
  };
})();
</script>
{% else %}
<script>
window.rpToggleWidget = function() {
  var popup = document.getElementById('rp-popup');
  popup.style.display = popup.style.display === 'none' ? 'block' : 'none';
};
</script>
{% endif %}

{% schema %}
{
  "name": "Reward Points Widget",
  "target": "body",
  "settings": [
    {
      "type": "color",
      "id": "button_color",
      "label": "Widget Color",
      "default": "#667eea"
    }
  ]
}
{% endschema %}