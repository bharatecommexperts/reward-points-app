{% comment %} extensions/reward-points-widget/blocks/reward-widget.liquid {% endcomment %}

<div id="reward-points-widget" class="reward-points-widget">
  {% if customer %}
    <div id="reward-loading">Loading your points...</div>
    <div id="reward-content" style="display:none;">
      <p>You have <strong id="reward-points-value">0</strong> points
        (worth <span id="reward-rupees-value">₹0</span>)</p>
      <button id="reward-redeem-btn" style="display:none;">Redeem Points</button>
      <p id="reward-min-message" style="display:none; color: #888; font-size: 14px;"></p>
    </div>
  {% else %}
    <p>{{ block.settings.login_message }}</p>
  {% endif %}
</div>

<script>
  (function () {
    {% if customer %}
    const customerId = "{{ customer.id }}";
    const shop = "{{ shop.permanent_domain }}";
    const baseUrl = "https://reward-points-app.onrender.com";

    // Points fetch karo
    fetch(`${baseUrl}/apps/rewards/points?customerId=${customerId}&shop=${shop}`, {
      headers: { "ngrok-skip-browser-warning": "true" }
    })
      .then((res) => res.json())
      .then((data) => {
        document.getElementById("reward-loading").style.display = "none";
        document.getElementById("reward-content").style.display = "block";
        document.getElementById("reward-points-value").textContent = data.totalPoints;
        document.getElementById("reward-rupees-value").textContent = "₹" + data.rupeesValue;

        const btn = document.getElementById("reward-redeem-btn");
        const minMsg = document.getElementById("reward-min-message");

        if (data.canRedeem) {
          btn.style.display = "inline-block";

          // Redeem button click handler
          btn.addEventListener("click", function () {
            btn.disabled = true;
            btn.textContent = "Processing...";

            fetch(`${baseUrl}/apps/rewards/redeem`, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "ngrok-skip-browser-warning": "true",
              },
              body: JSON.stringify({ customerId, shop }),
            })
              .then((res) => res.json())
              .then((redeemData) => {
                if (redeemData.success) {
                  // Success! Discount code dikhao
                  document.getElementById("reward-content").innerHTML = `
                    <div style="background: #f0fff4; border: 1px solid #68d391; padding: 16px; border-radius: 8px;">
                      <p style="color: #276749; font-weight: bold;">🎉 Points Redeemed Successfully!</p>
                      <p>Your discount code:</p>
                      <strong style="font-size: 20px; letter-spacing: 2px;">${redeemData.discountCode}</strong>
                      <p style="color: #666;">Worth ₹${redeemData.discountValue} off your order</p>
                      <p style="color: #888; font-size: 12px;">Apply this code at checkout</p>
                    </div>
                  `;
                } else {
                  btn.disabled = false;
                  btn.textContent = "Redeem Points";
                  alert(redeemData.error || "Something went wrong. Please try again.");
                }
              })
              .catch((err) => {
                btn.disabled = false;
                btn.textContent = "Redeem Points";
                console.error("Redeem error:", err);
                alert("Something went wrong. Please try again.");
              });
          });

        } else {
          minMsg.style.display = "block";
          minMsg.textContent = `You need at least ${data.minPointsToRedeem} points to redeem.`;
        }
      })
      .catch((err) => {
        console.error("Error fetching reward points:", err);
        document.getElementById("reward-loading").textContent = "Could not load points.";
      });
    {% endif %}
  })();
</script>

{% schema %}
{
  "name": "Reward Points Widget",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "login_message",
      "label": "Message for guests",
      "default": "Log in to see your reward points!"
    }
  ]
}
{% endschema %}